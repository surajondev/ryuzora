    "crafting_section_below_main": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n  .crafting-section {\n    width: 100%;\n    max-width: 100%;\n    padding: 20px 0 8px;\n    box-sizing: border-box;\n  }\n\n  .crafting-section__grid {\n    display: grid;\n    grid-template-columns: minmax(0, 1fr) minmax(320px, 460px);\n    gap: 32px;\n    align-items: center;\n  }\n\n  .crafting-section__title {\n    margin: 0 0 18px;\n    color: #002d1c;\n    font-size: clamp(1.9rem, 4vw, 3rem);\n    font-weight: 900;\n    line-height: 0.95;\n    text-transform: uppercase;\n  }\n\n  .crafting-section__copy {\n    margin: 0 0 24px;\n    max-width: 58ch;\n    color: rgba(0, 0, 0, 0.72);\n    font-size: 1rem;\n    line-height: 1.7;\n  }\n\n  .crafting-section__points {\n    display: grid;\n    gap: 18px;\n  }\n\n  .crafting-section__point {\n    display: grid;\n    grid-template-columns: 28px minmax(0, 1fr);\n    gap: 12px;\n    align-items: start;\n  }\n\n  .crafting-section__check {\n    width: 22px;\n    height: 22px;\n    margin-top: 2px;\n    border: 2px solid #002d1c;\n    border-radius: 50%;\n    color: #002d1c;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 0.8rem;\n    font-weight: 800;\n  }\n\n  .crafting-section__point-title {\n    margin: 0 0 4px;\n    color: #111;\n    font-size: 0.95rem;\n    font-weight: 800;\n    line-height: 1.2;\n    text-transform: uppercase;\n  }\n\n  .crafting-section__point-copy {\n    margin: 0;\n    color: rgba(0, 0, 0, 0.68);\n    font-size: 0.95rem;\n    line-height: 1.55;\n  }\n\n  .crafting-section__media-wrap {\n    position: relative;\n    padding: 22px 22px 0 0;\n  }\n\n  .crafting-section__media-frame {\n    position: absolute;\n    top: 18px;\n    right: 0;\n    bottom: 0;\n    left: 22px;\n    border: 2px solid #002d1c;\n    border-radius: 8px;\n    opacity: 0.75;\n  }\n\n  .crafting-section__media {\n    position: relative;\n    z-index: 1;\n    border-radius: 8px;\n    overflow: hidden;\n    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.14);\n    background: linear-gradient(135deg, #dde5e4, #f7f7f4);\n    aspect-ratio: 4 / 5;\n  }\n\n  .crafting-section__media img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n  }\n\n  @media screen and (max-width: 749px) {\n    .crafting-section {\n      padding-top: 8px;\n    }\n\n    .crafting-section__grid {\n      grid-template-columns: 1fr;\n      gap: 24px;\n    }\n\n    .crafting-section__title {\n      font-size: 1.8rem;\n    }\n\n    .crafting-section__copy {\n      margin-bottom: 18px;\n      font-size: 0.95rem;\n      line-height: 1.6;\n    }\n\n    .crafting-section__point-title,\n    .crafting-section__point-copy {\n      font-size: 0.9rem;\n    }\n\n    .crafting-section__media-wrap {\n      order: -1;\n      padding: 16px 16px 0 0;\n    }\n\n    .crafting-section__media-frame {\n      top: 12px;\n      left: 16px;\n    }\n  }\n</style>\n\n{% assign crafting_image = product.featured_image %}\n<div class=\"crafting-section\">\n  <div class=\"crafting-section__grid\">\n    <div class=\"crafting-section__content\">\n      <h2 class=\"crafting-section__title\">Crafting The Pitch On Paper</h2>\n      <p class=\"crafting-section__copy\">Every &ldquo;Anfield Blueprint&rdquo; is more than just a poster, it&rsquo;s a premium football wall frame made for fans who want iconic moments on their walls. Printed in high definition with rich fade-resistant inks, each piece is crafted to look sharp, elegant, and long-lasting in your room, office, or gifting setup.</p>\n      <div class=\"crafting-section__points\">\n        <div class=\"crafting-section__point\">\n          <div class=\"crafting-section__check\">&#10003;</div>\n          <div>\n            <p class=\"crafting-section__point-title\">250 GSM Premium Art Paper</p>\n            <p class=\"crafting-section__point-copy\">Thick, smooth, reflection-free paper that gives every line, detail, and stadium element a clean premium finish.</p>\n          </div>\n        </div>\n        <div class=\"crafting-section__point\">\n          <div class=\"crafting-section__check\">&#10003;</div>\n          <div>\n            <p class=\"crafting-section__point-title\">High-Quality Wooden Frame</p>\n            <p class=\"crafting-section__point-copy\">Strong wooden frame with clear protective front and sturdy MDF backing for a neat, durable display made to last.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"crafting-section__media-wrap\">\n      <div class=\"crafting-section__media-frame\"></div>\n      <div class=\"crafting-section__media\">\n        {% if crafting_image != blank %}\n          {{ crafting_image | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 42vw, 100vw', widths: '480, 720, 960, 1200', alt: product.title }}\n        {% endif %}\n      </div>\n    </div>\n  </div>\n</div>",
        "color_scheme": "scheme-1",
        "section_width": "page-width",
        "padding-block-start": 24,
        "padding-block-end": 24
      }
    },
    "process_hotspots_below": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n  .process-hotspots {\n    width: 100%;\n    max-width: 100%;\n    box-sizing: border-box;\n  }\n\n  .process-hotspots__header {\n    text-align: center;\n    margin-bottom: 24px;\n  }\n\n  .process-hotspots__eyebrow {\n    margin: 0 0 10px;\n    color: #002d1c;\n    font-size: 0.85rem;\n    font-weight: 800;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n  }\n\n  .process-hotspots__title {\n    margin: 0;\n    font-size: clamp(1.8rem, 4vw, 3rem);\n    font-weight: 900;\n    line-height: 0.95;\n    text-transform: uppercase;\n    color: #111;\n  }\n\n  .process-hotspots__stage {\n    width: min(100%, 980px);\n    margin: 0 auto;\n    padding: 28px;\n    border-radius: 26px;\n    background: linear-gradient(180deg, #fbfaf6 0%, #f2efe8 100%);\n  }\n\n  .process-hotspots__image-wrap {\n    position: relative;\n    width: min(100%, 460px);\n    margin: 0 auto;\n  }\n\n  .process-hotspots__poster {\n    position: relative;\n    z-index: 1;\n    border-radius: 22px;\n    overflow: hidden;\n    background: #fff;\n    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.12);\n  }\n\n  .process-hotspots__poster img {\n    display: block;\n    width: 100%;\n    aspect-ratio: var(--poster-ratio, 2 / 3);\n    object-fit: contain;\n    background: #fff;\n  }\n\n  .process-hotspots__item {\n    position: absolute;\n    z-index: 3;\n  }\n\n  .process-hotspots__button {\n    width: 34px;\n    height: 34px;\n    border-radius: 999px;\n    border: 2px solid rgba(255,255,255,0.95);\n    background: rgba(255,255,255,0.25);\n    backdrop-filter: blur(3px);\n    box-shadow: 0 10px 22px rgba(0,0,0,0.14);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    padding: 0;\n  }\n\n  .process-hotspots__button::after {\n    content: '';\n    width: 10px;\n    height: 10px;\n    border-radius: 999px;\n    background: #ffffff;\n  }\n\n  .process-hotspots__button.active {\n    border-color: #fcd400;\n    box-shadow: 0 0 0 4px rgba(252, 212, 0, 0.22), 0 10px 22px rgba(0,0,0,0.14);\n  }\n\n  .process-hotspots__card {\n    position: absolute;\n    width: min(240px, 26vw);\n    padding: 14px 16px;\n    border-radius: 16px;\n    background: #ffffff;\n    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.1);\n    opacity: 0;\n    pointer-events: none;\n    transition: opacity 0.18s ease, transform 0.18s ease;\n    transform: translateY(8px);\n  }\n\n  .process-hotspots__item:hover .process-hotspots__card,\n  .process-hotspots__item:focus-within .process-hotspots__card {\n    opacity: 1;\n    pointer-events: auto;\n    transform: translateY(0);\n  }\n\n  .process-hotspots__card h3,\n  .process-hotspots__mobile-card h3 {\n    margin: 0 0 6px;\n    font-size: 0.95rem;\n    font-weight: 800;\n    line-height: 1.15;\n    text-transform: uppercase;\n    color: #111;\n  }\n\n  .process-hotspots__card p,\n  .process-hotspots__mobile-card p {\n    margin: 0;\n    color: rgba(0,0,0,0.68);\n    font-size: 0.9rem;\n    line-height: 1.45;\n  }\n\n  .process-hotspots__item--1 { top: 19%; left: 21%; }\n  .process-hotspots__item--2 { top: 34%; right: 15%; }\n  .process-hotspots__item--3 { bottom: 24%; left: 15%; }\n  .process-hotspots__item--4 { bottom: 17%; right: 22%; }\n\n  .process-hotspots__item--1 .process-hotspots__card {\n    right: calc(100% + 16px);\n    top: 50%;\n    transform: translateY(-50%) translateY(8px);\n  }\n\n  .process-hotspots__item--1:hover .process-hotspots__card,\n  .process-hotspots__item--1:focus-within .process-hotspots__card {\n    transform: translateY(-50%);\n  }\n\n  .process-hotspots__item--2 .process-hotspots__card {\n    left: calc(100% + 16px);\n    top: 50%;\n    transform: translateY(-50%) translateY(8px);\n  }\n\n  .process-hotspots__item--2:hover .process-hotspots__card,\n  .process-hotspots__item--2:focus-within .process-hotspots__card {\n    transform: translateY(-50%);\n  }\n\n  .process-hotspots__item--3 .process-hotspots__card {\n    right: calc(100% + 16px);\n    bottom: -6px;\n  }\n\n  .process-hotspots__item--4 .process-hotspots__card {\n    left: calc(100% + 16px);\n    bottom: -6px;\n  }\n\n  .process-hotspots__mobile-rail {\n    display: none;\n  }\n\n  @media screen and (max-width: 749px) {\n    .process-hotspots__stage {\n      padding: 14px;\n      border-radius: 20px;\n    }\n\n    .process-hotspots__title {\n      font-size: 1.6rem;\n      line-height: 1;\n    }\n\n    .process-hotspots__image-wrap {\n      width: min(100%, 320px);\n    }\n\n    .process-hotspots__button {\n      width: 30px;\n      height: 30px;\n    }\n\n    .process-hotspots__button::after {\n      width: 9px;\n      height: 9px;\n    }\n\n    .process-hotspots__card {\n      display: none;\n    }\n\n    .process-hotspots__item--1 { top: 18%; left: 18%; }\n    .process-hotspots__item--2 { top: 34%; right: 10%; }\n    .process-hotspots__item--3 { bottom: 24%; left: 10%; }\n    .process-hotspots__item--4 { bottom: 16%; right: 18%; }\n\n    .process-hotspots__mobile-rail {\n      display: grid;\n      grid-auto-flow: column;\n      grid-auto-columns: minmax(270px, 78vw);\n      gap: 12px;\n      overflow-x: auto;\n      margin-top: 16px;\n      padding-bottom: 6px;\n      scroll-snap-type: x proximity;\n      -ms-overflow-style: none;\n      scrollbar-width: none;\n    }\n\n    .process-hotspots__mobile-rail::-webkit-scrollbar {\n      display: none;\n    }\n\n    .process-hotspots__mobile-card {\n      scroll-snap-align: start;\n      padding: 14px 16px;\n      border-radius: 16px;\n      background: #ffffff;\n      box-shadow: 0 10px 24px rgba(0,0,0,0.08);\n      border: 1px solid transparent;\n      transition: border-color 0.18s ease, box-shadow 0.18s ease;\n    }\n\n    .process-hotspots__mobile-card.active {\n      border-color: #fcd400;\n      box-shadow: 0 12px 26px rgba(0,0,0,0.12);\n    }\n\n    .process-hotspots__mobile-card h3 {\n      font-size: 0.88rem;\n    }\n\n    .process-hotspots__mobile-card p {\n      font-size: 0.86rem;\n      line-height: 1.45;\n    }\n  }\n</style>\n\n{% assign process_image = product.featured_image %}\n<div class=\"process-hotspots\" {% if process_image != blank %}style=\"--poster-ratio: {{ process_image.aspect_ratio }};\"{% endif %}>\n  <div class=\"process-hotspots__header\">\n    <p class=\"process-hotspots__eyebrow\">Why It Feels Premium</p>\n    <h2 class=\"process-hotspots__title\">Built To Stand Out</h2>\n  </div>\n  <div class=\"process-hotspots__stage\">\n    <div class=\"process-hotspots__image-wrap\">\n      <div class=\"process-hotspots__poster\">\n        {% if process_image != blank %}\n          {{ process_image | image_url: width: 1600 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 460px, 320px', widths: '480, 720, 960, 1200, 1600', alt: product.title }}\n        {% endif %}\n      </div>\n\n      <div class=\"process-hotspots__item process-hotspots__item--1\">\n        <button class=\"process-hotspots__button\" type=\"button\" aria-label=\"Premium print finish\" data-hotspot-target=\"1\"></button>\n        <div class=\"process-hotspots__card\">\n          <h3>Premium Print Finish</h3>\n          <p>Sharp detailing and rich colour output for a clean, premium football poster look.</p>\n        </div>\n      </div>\n\n      <div class=\"process-hotspots__item process-hotspots__item--2\">\n        <button class=\"process-hotspots__button\" type=\"button\" aria-label=\"Ready-to-display frame\" data-hotspot-target=\"2\"></button>\n        <div class=\"process-hotspots__card\">\n          <h3>Ready-To-Display Frame</h3>\n          <p>Framed neatly to look stylish in bedrooms, workspaces, and gifting setups.</p>\n        </div>\n      </div>\n\n      <div class=\"process-hotspots__item process-hotspots__item--3\">\n        <button class=\"process-hotspots__button\" type=\"button\" aria-label=\"Protective front cover\" data-hotspot-target=\"3\"></button>\n        <div class=\"process-hotspots__card\">\n          <h3>Protective Front Cover</h3>\n          <p>Keeps the artwork safer from dust and everyday handling while maintaining clarity.</p>\n        </div>\n      </div>\n\n      <div class=\"process-hotspots__item process-hotspots__item--4\">\n        <button class=\"process-hotspots__button\" type=\"button\" aria-label=\"Wall-friendly build\" data-hotspot-target=\"4\"></button>\n        <div class=\"process-hotspots__card\">\n          <h3>Wall-Friendly Build</h3>\n          <p>Light enough to hang easily and strong enough for long-term display.</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"process-hotspots__mobile-rail\" data-hotspot-rail>\n      <article class=\"process-hotspots__mobile-card active\" data-hotspot-card=\"1\">\n        <h3>Premium Print Finish</h3>\n        <p>Sharp detailing and rich colour output for a clean, premium football poster look.</p>\n      </article>\n      <article class=\"process-hotspots__mobile-card\" data-hotspot-card=\"2\">\n        <h3>Ready-To-Display Frame</h3>\n        <p>Framed neatly to look stylish in bedrooms, workspaces, and gifting setups.</p>\n      </article>\n      <article class=\"process-hotspots__mobile-card\" data-hotspot-card=\"3\">\n        <h3>Protective Front Cover</h3>\n        <p>Keeps the artwork safer from dust and everyday handling while maintaining clarity.</p>\n      </article>\n      <article class=\"process-hotspots__mobile-card\" data-hotspot-card=\"4\">\n        <h3>Wall-Friendly Build</h3>\n        <p>Light enough to hang easily and strong enough for long-term display.</p>\n      </article>\n    </div>\n  </div>\n</div>\n\n<script>\n  (() => {\n    const root = document.currentScript?.previousElementSibling;\n    if (!root) return;\n    const rail = root.querySelector('[data-hotspot-rail]');\n    const buttons = root.querySelectorAll('[data-hotspot-target]');\n    const cards = root.querySelectorAll('[data-hotspot-card]');\n    if (!rail || !buttons.length || !cards.length) return;\n\n    const setActive = (id) => {\n      buttons.forEach((button) => button.classList.toggle('active', button.dataset.hotspotTarget === id));\n      cards.forEach((card) => card.classList.toggle('active', card.dataset.hotspotCard === id));\n    };\n\n    buttons.forEach((button) => {\n      button.addEventListener('click', () => {\n        if (window.innerWidth > 749) return;\n        const id = button.dataset.hotspotTarget;\n        const card = root.querySelector(`[data-hotspot-card=\"${id}\"]`);\n        if (!card) return;\n        setActive(id);\n        rail.scrollTo({ left: card.offsetLeft - 14, behavior: 'smooth' });\n      });\n    });\n  })();\n</script>",
        "color_scheme": "scheme-1",
        "section_width": "page-width",
        "padding-block-start": 24,
        "padding-block-end": 24
      }
    },
