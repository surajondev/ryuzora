            "frame_features": {
              "type": "custom-liquid",
              "settings": {
                "custom_liquid": "<style>\n  .frame-features {\n    width: 100%;\n    max-width: 100%;\n    margin-top: 20px;\n    padding-top: 20px;\n    border-top: 1px solid rgba(0,0,0,0.08);\n    box-sizing: border-box;\n  }\n\n  .frame-features__grid {\n    width: 100%;\n    display: grid;\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n    gap: 18px 20px;\n  }\n\n  .frame-features__item {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    min-width: 0;\n  }\n\n  .frame-features__icon {\n    width: 64px;\n    height: 64px;\n    border-radius: 18px;\n    background: #ffd54f;\n    color: #002d1c;\n    flex: 0 0 64px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .frame-features__icon svg {\n    width: 28px;\n    height: 28px;\n    stroke: currentColor;\n    fill: none;\n    stroke-width: 1.8;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .frame-features__label {\n    margin: 0;\n    font-size: 1.05rem;\n    font-weight: 800;\n    line-height: 1.05;\n    text-transform: uppercase;\n  }\n\n  @media screen and (max-width: 749px) {\n    .frame-features__grid {\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      gap: 14px 12px;\n    }\n\n    .frame-features__item {\n      align-items: flex-start;\n      gap: 10px;\n    }\n\n    .frame-features__icon {\n      width: 52px;\n      height: 52px;\n      flex-basis: 52px;\n      border-radius: 15px;\n    }\n\n    .frame-features__icon svg {\n      width: 24px;\n      height: 24px;\n    }\n\n    .frame-features__label {\n      font-size: 0.78rem;\n      line-height: 1.08;\n    }\n  }\n</style>\n\n<div class=\"frame-features\">\n  <div class=\"frame-features__grid\">\n    <div class=\"frame-features__item\">\n      <div class=\"frame-features__icon\">\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M4 6.5h7v11H4z\"></path><path d=\"M13 6.5h7v11h-7z\"></path><path d=\"M6 9h3\"></path><path d=\"M15 9h3\"></path><path d=\"M6 12h3\"></path><path d=\"M15 12h3\"></path></svg>\n      </div>\n      <p class=\"frame-features__label\">Museum-Grade<br>Paper</p>\n    </div>\n    <div class=\"frame-features__item\">\n      <div class=\"frame-features__icon\">\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M4 20l4.5-1 9-9-3.5-3.5-9 9L4 20z\"></path><path d=\"M12.5 5.5l3.5 3.5\"></path></svg>\n      </div>\n      <p class=\"frame-features__label\">Giclee<br>Printing</p>\n    </div>\n    <div class=\"frame-features__item\">\n      <div class=\"frame-features__icon\">\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><rect x=\"5\" y=\"5\" width=\"14\" height=\"14\" rx=\"1\"></rect><path d=\"M8 15l3-3 2.5 2.5L16 12l3 3\"></path><circle cx=\"9\" cy=\"9\" r=\"1\"></circle></svg>\n      </div>\n      <p class=\"frame-features__label\">Handcrafted<br>Frames</p>\n    </div>\n    <div class=\"frame-features__item\">\n      <div class=\"frame-features__icon\">\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"8\"></circle><path d=\"M4 12h16\"></path><path d=\"M12 4a12 12 0 0 1 0 16\"></path><path d=\"M12 4a12 12 0 0 0 0 16\"></path></svg>\n      </div>\n      <p class=\"frame-features__label\">Fast<br>Shipping</p>\n    </div>\n  </div>\n</div>"
              },
