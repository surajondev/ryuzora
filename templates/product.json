              ]
            },
            "accordion_row_QkQxEz": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "Can I put carbonated drinks in it?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_TD6wV8": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Yes, you can use it for soda or sparkling water. However, be cautious when opening the lid as pressure from carbonation can cause minor splashing.</p>",
