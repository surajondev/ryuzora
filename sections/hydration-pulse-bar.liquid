{% comment %} StudioSip Hydration Pulse Bar - Phase 2 {% endcomment %}

{%- style -%}
  .hydration-pulse-bar {
    background-color: #A3B0A7;
    color: #ffffff;
    padding: 12px 20px;
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.3px;
    position: relative;
    z-index: 1000;
    transition: all 0.3s ease;
  }

  .hydration-pulse-bar:hover {
    background-color: #8F9A93;
  }

  .hydration-pulse-bar .pulse-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .hydration-pulse-bar .pulse-icon {
    width: 8px;
    height: 8px;
    background-color: #ffffff;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  .hydration-pulse-bar .pulse-text {
    color: #ffffff;
  }

  .hydration-pulse-bar .pulse-text strong {
    font-weight: 600;
  }

  .hydration-pulse-bar .pulse-badge {
    background-color: rgba(255, 255, 255, 0.2);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
  }

  @keyframes pulse {
    0% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.5);
      opacity: 0.7;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  {% if section.settings.enable_sticky %}
    .hydration-pulse-bar {
      position: sticky;
      top: 0;
    }
  {% endif %}

  {% if section.settings.enable_hide_mobile %}
    @media (max-width: 768px) {
      .hydration-pulse-bar {
        display: none;
      }
    }
  {% endif %}
{%- endstyle -%}

<div 
  class="hydration-pulse-bar" 
  id="hydration-pulse-{{ section.id }}"
  data-section-id="{{ section.id }}"
>
  <div class="pulse-content">
    <span class="pulse-icon"></span>
    <span class="pulse-text">
      {{ section.settings.pulse_text }}
    </span>
    <span class="pulse-badge">
      {{ section.settings.badge_text }}
    </span>
  </div>
</div>

{% schema %}
{
  "name": "Hydration Pulse Bar",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "pulse_text",
      "default": "Last 50 bottles hand-engraved in Thane today",
      "label": "Pulse Message"
    },
    {
      "type": "text",
      "id": "badge_text",
      "default": "✓ Made in Thane",
      "label": "Badge Text"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "default": true,
      "label": "Enable sticky positioning"
    },
    {
      "type": "checkbox",
      "id": "enable_hide_mobile",
      "default": false,
      "label": "Hide on mobile"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "Color scheme"
    }
  ],
  "presets": [
    {
      "name": "Hydration Pulse Bar"
    }
  ]
}
{% endschema %}
