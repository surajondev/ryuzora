{% comment %} StudioSip Urgency Banner - Phase 4 {% endcomment %}

{%- style -%}
  .studio-sip-urgency-banner {
    background: linear-gradient(135deg, #A3B0A7 0%, #8F9A93 100%);
    color: #ffffff;
    padding: 16px 20px;
    font-family: 'Inter', sans-serif;
    position: relative;
    overflow: hidden;
  }

  .studio-sip-urgency-banner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.5;
  }

  .studio-sip-urgency-banner .urgency-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    flex-wrap: wrap;
  }

  .studio-sip-urgency-banner .urgency-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .studio-sip-urgency-banner .urgency-icon {
    font-size: 20px;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-5px); }
    60% { transform: translateY(-3px); }
  }

  .studio-sip-urgency-banner .urgency-text {
    font-size: 14px;
    font-weight: 500;
  }

  .studio-sip-urgency-banner .urgency-text strong {
    font-weight: 700;
  }

  .studio-sip-urgency-banner .urgency-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .studio-sip-urgency-banner .countdown-timer {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.2);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
  }

  .studio-sip-urgency-banner .countdown-timer .timer-label {
    font-weight: 400;
    opacity: 0.9;
  }

  .studio-sip-urgency-banner .countdown-timer .timer-value {
    font-family: 'Inter', monospace;
    font-weight: 700;
    font-size: 15px;
  }

  .studio-sip-urgency-banner .urgency-cta {
    display: inline-block;
    padding: 8px 20px;
    background: #ffffff;
    color: #33363B;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .studio-sip-urgency-banner .urgency-cta:hover {
    background: #33363B;
    color: #ffffff;
    transform: scale(1.05);
  }

  @media (max-width: 768px) {
    .studio-sip-urgency-banner .urgency-content {
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }

    .studio-sip-urgency-banner .urgency-left {
      flex-direction: column;
    }
  }
{%- endstyle -%}

<div class="studio-sip-urgency-banner" id="urgency-banner-{{ section.id }}">
  <div class="urgency-content">
    <div class="urgency-left">
      <span class="urgency-icon">🔥</span>
      <span class="urgency-text">
        <strong>{{ section.settings.urgency_text }}</strong>
      </span>
    </div>
    
    <div class="urgency-right">
      {% if section.settings.enable_countdown %}
        <div class="countdown-timer">
          <span class="timer-label">Offer ends in:</span>
          <span class="timer-value" id="countdown-{{ section.id }}">24:00:00</span>
        </div>
      {% endif %}
      
      {% if section.settings.cta_text != blank %}
        <a href="{{ section.settings.cta_link }}" class="urgency-cta">
          {{ section.settings.cta_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% if section.settings.enable_countdown %}
<script>
  (function() {
    // Set countdown to end of day
    var countdownEl = document.getElementById('countdown-{{ section.id }}');
    if (!countdownEl) return;
    
    function updateCountdown() {
      var now = new Date();
      var endOfDay = new Date();
      endOfDay.setHours(23, 59, 59, 999);
      
      var diff = endOfDay - now;
      
      var hours = Math.floor(diff / (1000 * 60 * 60));
      var minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      var seconds = Math.floor((diff % (1000 * 60)) / 1000);
      
      countdownEl.textContent = 
        (hours < 10 ? '0' : '') + hours + ':' +
        (minutes < 10 ? '0' : '') + minutes + ':' +
        (seconds < 10 ? '0' : '') + seconds;
    }
    
    updateCountdown();
    setInterval(updateCountdown, 1000);
  })();
</script>
{% endif %}

{% schema %}
{
  "name": "StudioSip Urgency Banner",
  "settings": [
    {
      "type": "text",
      "id": "urgency_text",
      "default": "Free engraving on orders above ₹799!",
      "label": "Urgency Text"
    },
    {
      "type": "checkbox",
      "id": "enable_countdown",
      "default": true,
      "label": "Enable countdown timer"
    },
    {
      "type": "text",
      "id": "cta_text",
      "default": "Shop Now",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "StudioSip Urgency Banner"
    }
  ]
}
{% endschema %}
