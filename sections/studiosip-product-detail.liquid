{% comment %} StudioSip Product Detail with 360° Zoom & Customization - Phase 2 {% endcomment %}

<div class="studio-sip-product-detail" data-section-id="{{ section.id }}">
  <div class="product-main">
    <div class="product-gallery">
      {% render 'product-360-zoom', product: product %}
    </div>
    
    <div class="product-info">
      <div class="product-header">
        <h1 class="product-title">{{ product.title | escape }}</h1>
        
        <div class="product-price">
          {% render 'price', product: product, show_badges: true %}
        </div>
        
        {% if product.description != blank %}
          <div class="product-description rte">
            {{ product.description }}
          </div>
        {% endif %}
      </div>
      
      {% render 'product-customization', product: product %}
      
      {% form 'product', product, id: 'product-form', class: 'product-form' %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        
        <div class="product-variant-select">
          {% unless product.has_only_default_variant %}
            {% for option in product.options_with_values %}
              <div class="product-option">
                <label class="option-label">{{ option.name }}</label>
                <div class="option-values">
                  {% for value in option.values %}
                    <label class="option-value {% if option.selected_value == value %}selected{% endif %}">
                      <input 
                        type="radio" 
                        name="{{ option.name }}" 
                        value="{{ value }}"
                        {% if option.selected_value == value %}checked{% endif %}
                      >
                      <span class="value-label">{{ value }}</span>
                    </label>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          {% endunless %}
        </div>
        
        <div class="product-quantity">
          <label for="quantity" class="quantity-label">Quantity</label>
          <div class="quantity-selector">
            <button type="button" class="qty-btn minus" data-qty="minus">−</button>
            <input 
              type="number" 
              id="quantity" 
              name="quantity" 
              value="1" 
              min="1"
              class="qty-input"
            >
            <button type="button" class="qty-btn plus" data-qty="plus">+</button>
          </div>
        </div>
        
        <div class="product-submit">
          <button 
            type="submit" 
            name="add"
            class="submit-button"
            {% if product.selected_or_first_available_variant.available == false %}
              disabled
            {% endif %}
          >
            {% if product.selected_or_first_available_variant.available %}
              <span class="button-text">Add to Cart - {{ product.price | money }}</span>
            {% else %}
              <span class="button-text">Sold Out</span>
            {% endif %}
          </button>
        </div>
        
        <div class="product-stock-info">
          {% if product.selected_or_first_available_variant.available %}
            <span class="stock-status in-stock">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/>
                <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              In Stock - Ships from Thane
            </span>
          {% else %}
            <span class="stock-status out-of-stock">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/>
                <path d="M6 6l4 4M10 6l-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              Out of Stock
            </span>
          {% endif %}
        </div>
      {% endform %}
      
      <div class="product-trust-badges">
        <div class="trust-badge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Quality Assured</span>
        </div>
        <div class="trust-badge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Handcrafted in Thane</span>
        </div>
        <div class="trust-badge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <rect x="3" y="4" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M7 15h4M13 15h4M7 11h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>Free Shipping</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .studio-sip-product-detail {
    font-family: 'Inter', sans-serif;
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .studio-sip-product-detail .product-main {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  @media (max-width: 1024px) {
    .studio-sip-product-detail .product-main {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .studio-sip-product-detail .product-info {
    position: sticky;
    top: 100px;
  }

  .studio-sip-product-detail .product-title {
    font-family: 'Hatton', serif;
    font-size: 36px;
    font-weight: 600;
    color: #33363B;
    margin: 0 0 16px 0;
    line-height: 1.2;
  }

  .studio-sip-product-detail .product-price {
    margin-bottom: 24px;
  }

  .studio-sip-product-detail .product-price .price {
    font-family: 'Inter', sans-serif;
    font-size: 28px;
    font-weight: 600;
    color: #A3B0A7;
  }

  .studio-sip-product-detail .product-description {
    font-size: 15px;
    line-height: 1.7;
    color: #33363B;
    margin-bottom: 24px;
  }

  .studio-sip-product-detail .product-form {
    margin-top: 24px;
  }

  .studio-sip-product-detail .product-option {
    margin-bottom: 20px;
  }

  .studio-sip-product-detail .option-label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: #33363B;
    margin-bottom: 10px;
  }

  .studio-sip-product-detail .option-values {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .studio-sip-product-detail .option-value {
    cursor: pointer;
  }

  .studio-sip-product-detail .option-value input {
    display: none;
  }

  .studio-sip-product-detail .option-value .value-label {
    display: inline-block;
    padding: 10px 20px;
    border: 2px solid #E6E6E6;
    border-radius: 8px;
    font-size: 14px;
    color: #33363B;
    background: #ffffff;
    transition: all 0.3s ease;
  }

  .studio-sip-product-detail .option-value input:checked + .value-label,
  .studio-sip-product-detail .option-value.selected .value-label {
    border-color: #A3B0A7;
    background: rgba(163, 176, 167, 0.1);
    color: #33363B;
  }

  .studio-sip-product-detail .option-value:hover .value-label {
    border-color: #A3B0A7;
  }

  .studio-sip-product-detail .product-quantity {
    margin-bottom: 24px;
  }

  .studio-sip-product-detail .quantity-label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: #33363B;
    margin-bottom: 10px;
  }

  .studio-sip-product-detail .quantity-selector {
    display: flex;
    align-items: center;
    gap: 0;
    border: 2px solid #E6E6E6;
    border-radius: 8px;
    overflow: hidden;
    width: fit-content;
  }

  .studio-sip-product-detail .qty-btn {
    width: 48px;
    height: 48px;
    border: none;
    background: #F7F9FB;
    color: #33363B;
    font-size: 20px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .studio-sip-product-detail .qty-btn:hover {
    background: #A3B0A7;
    color: #ffffff;
  }

  .studio-sip-product-detail .qty-input {
    width: 60px;
    height: 48px;
    border: none;
    border-left: 1px solid #E6E6E6;
    border-right: 1px solid #E6E6E6;
    text-align: center;
    font-size: 16px;
    font-weight: 500;
    color: #33363B;
  }

  .studio-sip-product-detail .qty-input:focus {
    outline: none;
  }

  .studio-sip-product-detail .product-submit {
    margin-bottom: 20px;
  }

  .studio-sip-product-detail .submit-button {
    width: 100%;
    padding: 18px 32px;
    background: #A3B0A7;
    color: #ffffff;
    border: none;
    border-radius: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .studio-sip-product-detail .submit-button:hover {
    background: #8F9A93;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(163, 176, 167, 0.3);
  }

  .studio-sip-product-detail .submit-button:disabled {
    background: #E6E6E6;
    color: #999;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .studio-sip-product-detail .product-stock-info {
    margin-bottom: 24px;
  }

  .studio-sip-product-detail .stock-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 500;
  }

  .studio-sip-product-detail .stock-status.in-stock {
    color: #A3B0A7;
  }

  .studio-sip-product-detail .stock-status.out-of-stock {
    color: #d64545;
  }

  .studio-sip-product-detail .product-trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    padding-top: 24px;
    border-top: 1px solid #E6E6E6;
  }

  .studio-sip-product-detail .trust-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: #33363B;
    font-weight: 500;
  }

  .studio-sip-product-detail .trust-badge svg {
    color: #A3B0A7;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Quantity selector
    const qtyInput = document.querySelector('.qty-input');
    const minusBtn = document.querySelector('.qty-btn.minus');
    const plusBtn = document.querySelector('.qty-btn.plus');

    if (minusBtn && plusBtn && qtyInput) {
      minusBtn.addEventListener('click', function() {
        let current = parseInt(qtyInput.value);
        if (current > 1) {
          qtyInput.value = current - 1;
        }
      });

      plusBtn.addEventListener('click', function() {
        let current = parseInt(qtyInput.value);
        qtyInput.value = current + 1;
      });
    }
  });
</script>

{% schema %}
{
  "name": "StudioSip Product Detail",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "StudioSip Product Detail"
    }
  ]
}
{% endschema %}
