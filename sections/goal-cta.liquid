<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section class="section section--{{ section.settings.section_width }} goal-section color-{{ section.settings.color_scheme }}">
  {% if section.settings.heading != blank %}
    <h2 class="goal-section__title">{{ section.settings.heading | escape }}</h2>
  {% endif %}
  {% if section.settings.subheading != blank %}
    <div class="rte">{{ section.settings.subheading }}</div>
  {% endif %}
  {% form 'customer', class: 'goal-card' %}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <input type="email" name="contact[email]" placeholder="Email address" required>
    <button type="submit" class="goal-button">{{ section.settings.button_label | escape }}</button>
  {% endform %}
</section>

{% schema %}
{
  "name": "Goal CTA",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get Matchday Drops" },
    { "type": "richtext", "id": "subheading", "label": "Subheading", "default": "<p>New posters every week. Join the list.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Join Now" },
    { "type": "select", "id": "section_width", "label": "Section width", "default": "page-width", "options": [
      { "value": "page-width", "label": "Page" },
      { "value": "full-width", "label": "Full" }
    ]},
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "presets": [
    { "name": "Goal CTA" }
  ]
}
{% endschema %}
