<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section class="section section--{{ section.settings.section_width }} figma-bestsellers color-{{ section.settings.color_scheme }}">
  <div class="figma-bestsellers__header">
    {% if section.settings.heading != blank %}
      <h2 class="figma-section-title">{{ section.settings.heading }}</h2>
    {% endif %}
  </div>
  {% assign collection = section.settings.collection %}
  {% if collection != blank %}
    <div class="figma-bestsellers__grid">
      {% for product in collection.products limit: section.settings.products_count %}
        {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
      {% endfor %}
    </div>
    {% if section.settings.show_view_all %}
      <div class="figma-bestsellers__footer">
        <a class="figma-hero__button" href="{{ collection.url }}">{{ section.settings.view_all_label }}</a>
      </div>
    {% endif %}
  {% else %}
    <div class="goal-card">Select a collection to show bestsellers.</div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Figma Bestsellers",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Bestsellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_count", "label": "Products", "min": 4, "max": 12, "step": 1, "default": 8 },
    { "type": "checkbox", "id": "show_view_all", "label": "Show view all", "default": true },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View all" },
    { "type": "select", "id": "section_width", "label": "Section width", "default": "page-width", "options": [
      { "value": "page-width", "label": "Page" },
      { "value": "full-width", "label": "Full" }
    ]},
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "presets": [
    { "name": "Figma Bestsellers" }
  ]
}
{% endschema %}
