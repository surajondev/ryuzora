    </div>

    <div class="trust-badge-item">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <path d="M22 6l-10 7L2 6"/>
        </svg>
      </div>
      <h3 class="badge-title">Easy Returns</h3>
      <p class="badge-description">30-day hassle-free return policy</p>
    </div>

    <div class="trust-badge-item">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 6v6l4 2"/>
        </svg>
      </div>
      <h3 class="badge-title">Fast Delivery</h3>
      <p class="badge-description">3-5 business days across India</p>
    </div>

    <div class="trust-badge-item">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <path d="M12 8v4M12 16h.01"/>
        </svg>
      </div>
      <h3 class="badge-title">BPA Free</h3>
      <p class="badge-description">FDA-approved materials, 100% safe</p>
    </div>
  </div>
</div>

