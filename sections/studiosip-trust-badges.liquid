{% comment %} StudioSip Trust Badges - Phase 3 {% endcomment %}

{%- style -%}
  .studio-sip-trust-badges {
    padding: 60px 20px;
    background: #ffffff;
  }

  .studio-sip-trust-badges .badges-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  @media (max-width: 768px) {
    .studio-sip-trust-badges .badges-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (max-width: 480px) {
    .studio-sip-trust-badges .badges-container {
      grid-template-columns: 1fr;
    }
  }

  .studio-sip-trust-badges .trust-badge-item {
    text-align: center;
    padding: 24px 16px;
  }

  .studio-sip-trust-badges .badge-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 16px;
    background: #F7F9FB;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .studio-sip-trust-badges .trust-badge-item:hover .badge-icon {
    background: #A3B0A7;
    transform: scale(1.1);
  }

  .studio-sip-trust-badges .badge-icon svg {
    width: 28px;
    height: 28px;
    color: #A3B0A7;
    transition: color 0.3s ease;
  }

  .studio-sip-trust-badges .trust-badge-item:hover .badge-icon svg {
    color: #ffffff;
  }

  .studio-sip-trust-badges .badge-title {
    font-family: 'Hatton', serif;
    font-size: 18px;
    font-weight: 600;
    color: #33363B;
    margin: 0 0 8px 0;
  }

  .studio-sip-trust-badges .badge-description {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #666;
    margin: 0;
    line-height: 1.5;
  }

  .studio-sip-trust-badges.thane-edition {
    background: #F7F9FB;
    border-radius: 16px;
    margin: 40px 20px;
    padding: 48px 20px;
  }

  .studio-sip-trust-badges.thane-edition .section-title {
    text-align: center;
    font-family: 'Hatton', serif;
    font-size: 28px;
    font-weight: 600;
    color: #33363B;
    margin: 0 0 8px 0;
  }

  .studio-sip-trust-badges.thane-edition .section-subtitle {
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #A3B0A7;
    margin: 0 0 40px 0;
  }

  .studio-sip-trust-badges.thane-edition .badges-container {
    grid-template-columns: repeat(3, 1fr);
  }

  @media (max-width: 768px) {
    .studio-sip-trust-badges.thane-edition .badges-container {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<div class="studio-sip-trust-badges thane-edition">
  <h2 class="section-title">Why Choose StudioSip?</h2>
  <p class="section-subtitle">Premium quality, locally crafted</p>
  
  <div class="badges-container">
    <div class="trust-badge-item">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
      </div>
      <h3 class="badge-title">Quality Assured</h3>
      <p class="badge-description">Type I Borosilicate Glass, heat-resistant up to 350°C</p>
    </div>

    <div class="trust-badge-item">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
      </div>
      <h3 class="badge-title">Handcrafted in Thane</h3>
      <p class="badge-description">Each bottle hand-engraved by local artisans</p>
    </div>

    <div class="trust-badge-item">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="4" width="18" height="16" rx="2"/>
          <path d="M7 15h4M13 15h4M7 11h10"/>
        </svg>
      </div>
      <h3 class="badge-title">Free Shipping</h3>
