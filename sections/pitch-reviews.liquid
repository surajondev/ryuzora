<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section class="section section--{{ section.settings.section_width }} pitch-reviews color-{{ section.settings.color_scheme }}">
  <div class="pitch-reviews__header">
    {% if section.settings.heading != blank %}
      <h2 class="pitch-section-title pitch-section-title--light">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="pitch-reviews__subtitle">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>
  <div class="pitch-reviews__grid">
    {% for block in section.blocks %}
      <div class="pitch-reviews__card" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <div class="pitch-reviews__image">
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
          </div>
        {% endif %}
        <div class="pitch-reviews__content">
          {% if block.settings.title != blank %}
            <div class="pitch-reviews__title">{{ block.settings.title }}</div>
          {% endif %}
          {% if block.settings.body != blank %}
            <div class="pitch-reviews__body">{{ block.settings.body }}</div>
          {% endif %}
          {% if block.settings.author != blank %}
            <div class="pitch-reviews__author">{{ block.settings.author }}</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Pitch Reviews",
  "class": "section-wrapper",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "LOVED BY THOUSANDS" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Real fans. Real stories." },
    { "type": "select", "id": "section_width", "label": "Section width", "default": "page-width", "options": [
      { "value": "page-width", "label": "Page" },
      { "value": "full-width", "label": "Full" }
    ]},
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "review_card",
      "name": "Review",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Perfect gift" },
        { "type": "text", "id": "body", "label": "Body", "default": "The quality is unreal and shipping was fast." },
        { "type": "text", "id": "author", "label": "Author", "default": "Alex M." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pitch Reviews",
      "blocks": [
        { "type": "review_card" },
        { "type": "review_card" },
        { "type": "review_card" }
      ]
    }
  ]
}
{% endschema %}
