<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section class="section section--{{ section.settings.section_width }} goal-section color-{{ section.settings.color_scheme }}">
  {% if section.settings.heading != blank %}
    <h2 class="goal-section__title">{{ section.settings.heading | escape }}</h2>
  {% endif %}
  <div class="goal-grid">
    {% for block in section.blocks %}
      <div class="goal-card" {{ block.shopify_attributes }}>
        <div class="goal-card__title">{{ block.settings.title | escape }}</div>
        <div class="goal-card__text">{{ block.settings.text }}</div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Goal How It Works",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "How It Works" },
    { "type": "select", "id": "section_width", "label": "Section width", "default": "page-width", "options": [
      { "value": "page-width", "label": "Page" },
      { "value": "full-width", "label": "Full" }
    ]},
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Pick the Match" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Select your favorite moment from our curated matches.</p>" }
      ]
    }
  ],
  "presets": [
    { "name": "Goal How It Works", "blocks": [
      { "type": "step" },
      { "type": "step" },
      { "type": "step" }
    ] }
  ]
}
{% endschema %}
