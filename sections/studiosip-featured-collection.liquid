{% comment %} StudioSip Featured Collection - Premium Grid - Phase 3 {% endcomment %}

{%- style -%}
  .studio-sip-featured-collection {
    padding: 80px 20px;
    background-color: #F7F9FB;
  }

  .studio-sip-featured-collection .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .studio-sip-featured-collection .section-title {
    font-family: 'Hatton', serif;
    font-size: 42px;
    font-weight: 600;
    color: #33363B;
    margin: 0 0 12px 0;
  }

  .studio-sip-featured-collection .section-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #A3B0A7;
    margin: 0;
    font-weight: 500;
  }

  .studio-sip-featured-collection .collection-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    max-width: 1400px;
    margin: 0 auto;
  }

  @media (max-width: 1024px) {
    .studio-sip-featured-collection .collection-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .studio-sip-featured-collection .collection-grid {
      grid-template-columns: 1fr;
    }
    
    .studio-sip-featured-collection .section-title {
      font-size: 32px;
    }
  }

  .studio-sip-featured-collection .product-card {
    background: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.4s ease;
    position: relative;
  }

  .studio-sip-featured-collection .product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(51, 54, 59, 0.12);
  }

  .studio-sip-featured-collection .card-media {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: #ffffff;
  }

  .studio-sip-featured-collection .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .studio-sip-featured-collection .product-card:hover .card-media img {
    transform: scale(1.05);
  }

  .studio-sip-featured-collection .card-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #A3B0A7;
    color: #ffffff;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-family: 'Inter', sans-serif;
  }

  .studio-sip-featured-collection .card-quick-add {
    position: absolute;
    bottom: 12px;
    left: 12px;
    right: 12px;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s ease;
  }

  .studio-sip-featured-collection .product-card:hover .card-quick-add {
    opacity: 1;
    transform: translateY(0);
  }

  .studio-sip-featured-collection .quick-add-btn {
    width: 100%;
    padding: 12px;
    background: #33363B;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .studio-sip-featured-collection .quick-add-btn:hover {
    background: #A3B0A7;
  }

  .studio-sip-featured-collection .card-information {
    padding: 20px;
  }

  .studio-sip-featured-collection .card-title {
    font-family: 'Hatton', serif;
    font-size: 18px;
    font-weight: 600;
    color: #33363B;
    margin: 0 0 8px 0;
    line-height: 1.3;
  }

  .studio-sip-featured-collection .card-title a {
    color: inherit;
    text-decoration: none;
  }

  .studio-sip-featured-collection .card-title a:hover {
    color: #A3B0A7;
  }

  .studio-sip-featured-collection .card-price {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #A3B0A7;
    margin: 0 0 12px 0;
  }

  .studio-sip-featured-collection .card-engraving-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: #A3B0A7;
    font-weight: 500;
  }

  .studio-sip-featured-collection .view-all-container {
    text-align: center;
    margin-top: 48px;
  }

  .studio-sip-featured-collection .view-all-btn {
    display: inline-block;
    padding: 14px 32px;
    background: transparent;
    color: #33363B;
    border: 2px solid #33363B;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .studio-sip-featured-collection .view-all-btn:hover {
    background: #33363B;
    color: #ffffff;
  }
{%- endstyle -%}

<div class="studio-sip-featured-collection">
  <div class="section-header">
    <h2 class="section-title">{{ section.settings.title | escape }}</h2>
    <p class="section-subtitle">{{ section.settings.subtitle | escape }}</p>
  </div>

  <div class="collection-grid">
    {%- for product in section.settings.collection.products limit: section.settings.products_count -%}
      <div class="product-card">
        <div class="card-media">
          <a href="{{ product.url }}">
            {% if product.featured_image != blank %}
              <img 
                src="{{ product.featured_image | image_url: width: 600 }}" 
                alt="{{ product.title | escape }}"
                width="300"
                height="300"
                loading="lazy"
              >
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </a>
          
          {% if product.metafields.custom.engraving_available %}
            <span class="card-badge">✓ Customizable</span>
          {% endif %}
          
          <div class="card-quick-add">
            <button class="quick-add-btn" onclick="location.href='{{ product.url }}'">
              Quick Add
            </button>
          </div>
        </div>
        
        <div class="card-information">
          <h3 class="card-title">
            <a href="{{ product.url }}">{{ product.title }}</a>
          </h3>
          <div class="card-price">
            <span class="price-item price-item--regular">
              {{ product.price | money }}
            </span>
          </div>
          {% if product.metafields.custom.engraving_available %}
            <div class="card-engraving-tag">
              <span>🎋</span>
              <span>Personalized engraving available</span>
            </div>
          {% endif %}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {% if section.settings.show_view_all %}
    <div class="view-all-container">
      <a href="{{ section.settings.collection.url }}" class="view-all-btn">
        View All Products
      </a>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "The StudioSip Collection",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subtitle",
      "default": "Handcrafted in Thane, designed for your desk",
      "label": "Subtitle"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show View All button"
    }
  ],
  "presets": [
    {
      "name": "StudioSip Featured Collection"
    }
  ]
}
{% endschema %}
