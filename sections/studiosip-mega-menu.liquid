{% comment %} StudioSip Mega Menu - Phase 4 {% endcomment %}

{%- style -%}
  .studio-sip-mega-menu {
    font-family: 'Inter', sans-serif;
  }

  .studio-sip-mega-menu .mega-menu-container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    padding: 32px 40px;
    max-width: 1400px;
    margin: 0 auto;
  }

  @media (max-width: 1024px) {
    .studio-sip-mega-menu .mega-menu-container {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .studio-sip-mega-menu .mega-menu-container {
      grid-template-columns: 1fr;
      padding: 24px;
    }
  }

  .studio-sip-mega-menu .mega-menu-column {
    min-width: 200px;
  }

  .studio-sip-mega-menu .menu-heading {
    font-family: 'Hatton', serif;
    font-size: 16px;
    font-weight: 600;
    color: #33363B;
    margin: 0 0 16px 0;
    padding-bottom: 12px;
    border-bottom: 2px solid #A3B0A7;
  }

  .studio-sip-mega-menu .menu-items {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .studio-sip-mega-menu .menu-items li {
    margin-bottom: 10px;
  }

  .studio-sip-mega-menu .menu-items a {
    font-size: 14px;
    color: #666;
    text-decoration: none;
    transition: color 0.3s ease;
    display: block;
    padding: 6px 0;
  }

  .studio-sip-mega-menu .menu-items a:hover {
    color: #A3B0A7;
    padding-left: 8px;
  }

  .studio-sip-mega-menu .menu-featured {
    background: #F7F9FB;
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    margin-top: 16px;
  }

  .studio-sip-mega-menu .featured-image {
    width: 100%;
    height: 120px;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 12px;
  }

  .studio-sip-mega-menu .featured-title {
    font-family: 'Hatton', serif;
    font-size: 14px;
    font-weight: 600;
    color: #33363B;
    margin: 0 0 8px 0;
  }

  .studio-sip-mega-menu .featured-price {
    font-size: 13px;
    color: #A3B0A7;
    font-weight: 600;
  }

  .studio-sip-mega-menu .menu-badge {
    display: inline-block;
    background: #A3B0A7;
    color: #ffffff;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 3px 8px;
    border-radius: 10px;
    margin-left: 8px;
  }
{%- endstyle -%}

<div class="studio-sip-mega-menu" id="mega-menu-{{ section.id }}">
  <div class="mega-menu-container">
    <div class="mega-menu-column">
      <h4 class="menu-heading">Shop by Size</h4>
      <ul class="menu-items">
        <li><a href="{{ routes.collections_url }}/550ml">550ml Bottles</a></li>
        <li><a href="{{ routes.collections_url }}/750ml">750ml Bottles</a></li>
        <li><a href="{{ routes.collections_url }}/1200ml">1200ml Tumblers</a></li>
        <li><a href="{{ routes.collections_url }}/accessories">Accessories</a></li>
      </ul>
    </div>

    <div class="mega-menu-column">
      <h4 class="menu-heading">Collections</h4>
      <ul class="menu-items">
        <li><a href="{{ routes.collections_url }}/new-arrivals">New Arrivals <span class="menu-badge">New</span></a></li>
        <li><a href="{{ routes.collections_url }}/best-sellers">Best Sellers</a></li>
        <li><a href="{{ routes.collections_url }}/personalized">Personalized</a></li>
        <li><a href="{{ routes.collections_url }}/gift-sets">Gift Sets</a></li>
      </ul>
    </div>

    <div class="mega-menu-column">
      <h4 class="menu-heading">Customization</h4>
      <ul class="menu-items">
        <li><a href="{{ routes.collections_url }}/engraved">Laser Engraved</a></li>
        <li><a href="{{ routes.collections_url }}/custom-logo">Logo Customization</a></li>
        <li><a href="{{ routes.collections_url }}/corporate-gifts">Corporate Orders</a></li>
        <li><a href="{{ routes.page_url }}/customization-guide">Customization Guide</a></li>
      </ul>
    </div>

    <div class="mega-menu-column">
      <div class="menu-featured">
        {% if section.settings.featured_product != blank %}
          {% assign product = section.settings.featured_product %}
          <img 
            src="{{ product.featured_image | image_url: width: 300 }}" 
            alt="{{ product.title }}"
            class="featured-image"
          >
          <h5 class="featured-title">{{ product.title }}</h5>
          <span class="featured-price">{{ product.price | money }}</span>
        {% else %}
          <img 
            src="https://placehold.co/300x200/F7F9FB/A3B0A7?text=Featured+Product" 
            alt="Featured Product"
            class="featured-image"
          >
          <h5 class="featured-title">StudioSip Premium Set</h5>
          <span class="featured-price">₹999</span>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "StudioSip Mega Menu",
  "settings": [
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Product"
    }
  ],
  "presets": [
    {
      "name": "StudioSip Mega Menu"
    }
  ]
}
{% endschema %}
