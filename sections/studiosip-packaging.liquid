{% comment %} StudioSip Premium Packaging Showcase - Phase 3 {% endcomment %}

{%- style -%}
  .studio-sip-packaging {
    padding: 80px 20px;
    background: linear-gradient(135deg, #F7F9FB 0%, #ffffff 100%);
    overflow: hidden;
  }

  .studio-sip-packaging .packaging-container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  @media (max-width: 900px) {
    .studio-sip-packaging .packaging-container {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .studio-sip-packaging .packaging-image {
    position: relative;
  }

  .studio-sip-packaging .packaging-image-main {
    width: 100%;
    max-width: 500px;
    height: auto;
    border-radius: 20px;
    box-shadow: 0 30px 60px rgba(51, 54, 59, 0.15);
  }

  .studio-sip-packaging .packaging-badge {
    position: absolute;
    top: 20px;
    right: 20px;
    background: #A3B0A7;
    color: #ffffff;
    padding: 12px 20px;
    border-radius: 30px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .studio-sip-packaging .packaging-content {
    padding: 20px;
  }

  .studio-sip-packaging .packaging-label {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: #A3B0A7;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 16px;
  }

  .studio-sip-packaging .packaging-title {
    font-family: 'Hatton', serif;
    font-size: 42px;
    font-weight: 600;
    color: #33363B;
    margin: 0 0 20px 0;
    line-height: 1.2;
  }

  .studio-sip-packaging .packaging-description {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #666;
    margin: 0 0 32px 0;
    line-height: 1.7;
  }

  .studio-sip-packaging .packaging-features {
    list-style: none;
    padding: 0;
    margin: 0 0 32px 0;
  }

  .studio-sip-packaging .packaging-features li {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    color: #33363B;
    border-bottom: 1px solid #E6E6E6;
  }

  .studio-sip-packaging .packaging-features li:last-child {
    border-bottom: none;
  }

  .studio-sip-packaging .feature-icon {
    width: 24px;
    height: 24px;
    background: #A3B0A7;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .studio-sip-packaging .feature-icon svg {
    width: 12px;
    height: 12px;
    color: #ffffff;
  }

  .studio-sip-packaging .packaging-cta {
    display: inline-block;
    padding: 16px 32px;
    background: #33363B;
    color: #ffffff;
    border-radius: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .studio-sip-packaging .packaging-cta:hover {
    background: #A3B0A7;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(163, 176, 167, 0.3);
  }

  .studio-sip-packaging .comparison-table {
    margin-top: 40px;
    background: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(51, 54, 59, 0.08);
  }

  .studio-sip-packaging .comparison-table table {
    width: 100%;
    border-collapse: collapse;
  }

  .studio-sip-packaging .comparison-table th,
  .studio-sip-packaging .comparison-table td {
    padding: 16px 20px;
    text-align: left;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
  }

  .studio-sip-packaging .comparison-table th {
    background: #F7F9FB;
    font-weight: 600;
    color: #33363B;
  }

  .studio-sip-packaging .comparison-table th:first-child {
    width: 40%;
  }

  .studio-sip-packaging .comparison-table td {
    color: #666;
    border-top: 1px solid #E6E6E6;
  }

  .studio-sip-packaging .comparison-table td:last-child {
    color: #A3B0A7;
    font-weight: 600;
  }

  .studio-sip-packaging .comparison-table tr:first-child td {
    border-top: none;
  }
{%- endstyle -%}

<div class="studio-sip-packaging">
  <div class="packaging-container">
    <div class="packaging-image">
      {% if section.settings.packaging_image != blank %}
        <img 
          src="{{ section.settings.packaging_image | image_url: width: 800 }}" 
          alt="StudioSip Premium Packaging"
          class="packaging-image-main"
          width="500"
          height="auto"
          loading="lazy"
        >
      {% else %}
        <div class="packaging-placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {% endif %}
      <span class="packaging-badge">Premium Unboxing</span>
    </div>

    <div class="packaging-content">
      <span class="packaging-label">Packaging</span>
      <h2 class="packaging-title">Experience Premium Unboxing</h2>
      <p class="packaging-description">
        Every StudioSip bottle arrives in a beautifully crafted matte-finish cylinder box, 
        designed to protect your bottle and make unboxing a memorable experience.
      </p>

      <ul class="packaging-features">
        <li>
          <span class="feature-icon">
            <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 6l3 3 5-5"/>
            </svg>
          </span>
          Matte-finish custom cylinder box
        </li>
        <li>
          <span class="feature-icon">
            <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 6l3 3 5-5"/>
            </svg>
          </span>
          Eco-friendly sustainable materials
        </li>
        <li>
          <span class="feature-icon">
            <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 6l3 3 5-5"/>
            </svg>
          </span>
          Protective foam inserts
        </li>
        <li>
          <span class="feature-icon">
            <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 6l3 3 5-5"/>
            </svg>
          </span>
          Gift-ready presentation
        </li>
      </ul>

      <a href="{{ section.settings.cta_link }}" class="packaging-cta">
        {{ section.settings.cta_text | default: 'Shop Now' }}
      </a>

      <div class="comparison-table">
        <table>
          <thead>
            <tr>
              <th>Feature</th>
              <th>StudioSip</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Packaging</td>
              <td>Custom cylinder box</td>
            </tr>
            <tr>
              <td>Finish</td>
              <td>Matte premium</td>
            </tr>
            <tr>
              <td>Protection</td>
              <td>Foam inserts</td>
            </tr>
            <tr>
              <td>Experience</td>
              <td>Gift-ready</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Premium Packaging",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "packaging_image",
      "label": "Packaging Image"
    },
    {
      "type": "text",
      "id": "cta_text",
      "default": "Shop Now",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "StudioSip Premium Packaging"
    }
  ]
}
{% endschema %}
