<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section class="section section--{{ section.settings.section_width }} pitch-quality color-{{ section.settings.color_scheme }}">
  <div class="pitch-quality__grid">
    <div class="pitch-quality__media">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'lazy', sizes: '100vw' }}
      {% endif %}
      <div class="pitch-quality__media-content">
        {% if section.settings.media_heading != blank %}
          <h3 class="pitch-quality__media-title">{{ section.settings.media_heading }}</h3>
        {% endif %}
        {% if section.settings.media_button_label != blank %}
          <a class="pitch-quality__media-button" href="{{ section.settings.media_button_link }}">{{ section.settings.media_button_label }}</a>
        {% endif %}
      </div>
    </div>
    <div class="pitch-quality__panel">
      {% if section.settings.panel_heading != blank %}
        <h3 class="pitch-quality__panel-title">{{ section.settings.panel_heading }}</h3>
      {% endif %}
      {% if section.settings.panel_subheading != blank %}
        <p class="pitch-quality__panel-subtitle">{{ section.settings.panel_subheading }}</p>
      {% endif %}
      <div class="pitch-quality__steps">
        {% for block in section.blocks %}
          <div class="pitch-quality__step" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <div class="pitch-quality__icon">
                {{ block.settings.icon | image_url: width: 120 | image_tag: loading: 'lazy' }}
              </div>
            {% endif %}
            <div class="pitch-quality__step-text">
              <div class="pitch-quality__step-title">{{ block.settings.title }}</div>
              <div class="pitch-quality__step-body">{{ block.settings.body }}</div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pitch Quality",
  "class": "section-wrapper",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Media image" },
    { "type": "text", "id": "media_heading", "label": "Media heading", "default": "PRODUCTION QUALITY" },
    { "type": "text", "id": "media_button_label", "label": "Media button label", "default": "VIEW DETAILS" },
    { "type": "url", "id": "media_button_link", "label": "Media button link" },
    { "type": "text", "id": "panel_heading", "label": "Panel heading", "default": "SEE HOW IT WORKS" },
    { "type": "text", "id": "panel_subheading", "label": "Panel subheading", "default": "Every poster is created with intentional precision." },
    { "type": "select", "id": "section_width", "label": "Section width", "default": "page-width", "options": [
      { "value": "page-width", "label": "Page" },
      { "value": "full-width", "label": "Full" }
    ]},
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "quality_step",
      "name": "Step",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "title", "label": "Title", "default": "Select your moment" },
        { "type": "text", "id": "body", "label": "Body", "default": "Choose a match and customize the poster." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pitch Quality",
      "blocks": [
        { "type": "quality_step" },
        { "type": "quality_step" },
        { "type": "quality_step" }
      ]
    }
  ]
}
{% endschema %}
